<script>
  // ── TOOLTIP ENGINE ──
  // Single fixed bubble on body, positioned by JS relative to viewport.
  // Never inside any scrolling or overflow container, so it can never be clipped.
  const tipBubble = document.getElementById('tipBubble');
  let tipTimer;

  document.addEventListener('mouseover', e => {
    const icon = e.target.closest('.tip-icon');
    if (!icon) return;
    clearTimeout(tipTimer);
    tipBubble.textContent = icon.dataset.tip || '';
    placeTip(icon);
    tipBubble.classList.add('show');
  });

  document.addEventListener('mouseout', e => {
    if (e.target.closest('.tip-icon')) tipTimer = setTimeout(() => tipBubble.classList.remove('show'), 80);
  });

  window.addEventListener('scroll', () => tipBubble.classList.remove('show'), { passive: true });
  window.addEventListener('resize', () => tipBubble.classList.remove('show'), { passive: true });

  function placeTip(icon) {
    const W = 240, M = 10;
    const vw = window.innerWidth, vh = window.innerHeight;
    const r  = icon.getBoundingClientRect();

    // Measure bubble height by rendering off-screen
    tipBubble.style.cssText = `width:${W}px;top:-9999px;left:-9999px;display:block`;
    const bh = tipBubble.offsetHeight;
    tipBubble.style.display = '';

    // Horizontal: align left of icon, clamp to viewport
    let left = Math.min(Math.max(r.left, M), vw - W - M);

    // Vertical: prefer above, fall back to below
    let top = r.top - bh - 8;
    if (top < M) top = r.bottom + 8;
    top = Math.min(top, vh - bh - M);

    tipBubble.style.cssText = `width:${W}px;left:${left}px;top:${top}px`;
  }

  // ── TOGGLE HELPERS ──
  function toggleAdjust() {
    const body = document.getElementById('adjustBody');
    const head = document.getElementById('adjustHeader');
    const open = body.classList.toggle('open');
    head.classList.toggle('open', open);
  }

  function toggleMeth() {
    const body  = document.getElementById('methBody');
    const label = document.getElementById('methLabel');
    body.classList.toggle('open');
    label.innerHTML = body.classList.contains('open')
      ? 'Hide <span style="font-size:10px;margin-left:4px">&#9650;</span>'
      : 'Show <span style="font-size:10px;margin-left:4px">&#9660;</span>';
  }

  function handleWD() {
    document.getElementById('customDaysField').style.display =
      document.getElementById('workingDays').value === 'custom' ? 'block' : 'none';
    calculate();
  }

  // ── SLIDERS ──
  function onSlider() {
    const bv = parseInt(document.getElementById('altBumpSlider').value);
    const cv = parseInt(document.getElementById('altCalSlider').value);
    document.getElementById('altBumpDisplay').textContent = bv;
    document.getElementById('altCalDisplay').textContent  = cv;
    track('altBumpSlider', 1,  30);
    track('altCalSlider',  30, 180);
    calculate();
  }

  function track(id, min, max) {
    const s = document.getElementById(id);
    const p = ((parseInt(s.value) - min) / (max - min)) * 100;
    s.style.background = `linear-gradient(to right,var(--red) ${p}%,var(--border) ${p}%)`;
  }

  // ── HELPERS ──
  const fmt  = n => (n == null || isNaN(n)) ? '-' : '$' + Math.round(n).toLocaleString('en-US');
  const fmtN = n => (n == null || isNaN(n)) ? '-' : Math.round(n).toLocaleString('en-US');
  const fmtL = n => (!n || isNaN(n))        ? '-' : Math.round(n).toLocaleString('en-US') + ' L';
  const gv   = (id, fb=0) => { const v = parseFloat(document.getElementById(id).value); return isNaN(v) ? fb : v; };
  const set  = (id, v)    => { document.getElementById(id).textContent = v; };

  // ── PROGRESS NUDGE ──
  function updateNudge(d, cs, cc, tt, hr) {
    const miss = [];
    if (!d)  miss.push('number of devices');
    if (!cs) miss.push('cylinder size');
    if (!cc) miss.push('cylinder cost');
    if (!tt) miss.push('time per test');
    if (!hr) miss.push('hourly rate');
    const partial = (d||cs||cc||tt||hr) && miss.length;
    const el = document.getElementById('progressNudge');
    if (partial) { document.getElementById('nudgeFields').textContent = miss.join(', '); el.classList.add('visible'); }
    else { el.classList.remove('visible'); }
  }

  // ── RESET ──
  function resetAll() {
    ['devices','customDays','cylinderSize','cylinderCost','gasPerBump','timePerTest',
     'hourlyRate','confinedSpace','devicesPerCS','eligibleDevices']
      .forEach(id => document.getElementById(id).value = '');
    document.getElementById('workingDays').value = '220';
    document.getElementById('currentBump').value = '1';
    document.getElementById('currentCal').value  = '30';
    document.getElementById('cylinderEff').value = '0.85';
    document.getElementById('retestRate').value  = '0';
    document.getElementById('customDaysField').style.display = 'none';
    document.getElementById('altBumpSlider').value = '30';
    document.getElementById('altCalSlider').value  = '180';
    document.getElementById('altBumpDisplay').textContent = '30';
    document.getElementById('altCalDisplay').textContent  = '180';
    track('altBumpSlider', 1, 30);
    track('altCalSlider', 30, 180);
    ['bumpSameWarn','calSameWarn'].forEach(id => document.getElementById(id).classList.remove('show'));
    document.getElementById('eligibleSplit').style.display = 'none';
    document.getElementById('results').style.display = 'none';
    document.getElementById('progressNudge').classList.remove('visible');
    document.getElementById('savingBanner').classList.remove('show');
    window.scrollTo({ top:0, behavior:'smooth' });
  }

  // ── CORE CALCULATION ──
  function calculate() {
    const devices     = gv('devices');
    const wdSel       = document.getElementById('workingDays').value;
    const wd          = wdSel === 'custom' ? gv('customDays', 220) : parseFloat(wdSel);
    const curBump     = gv('currentBump', 1);
    const curCal      = gv('currentCal', 30);
    const cylSz       = gv('cylinderSize');
    const cylCost     = gv('cylinderCost');
    const gpb         = gv('gasPerBump') || 0.5;
    const tpt         = gv('timePerTest');
    const hr          = gv('hourlyRate');
    const cylEff      = parseFloat(document.getElementById('cylinderEff').value);
    const retest      = parseFloat(document.getElementById('retestRate').value);
    const csWk        = gv('confinedSpace');
    const dpcs        = gv('devicesPerCS') || 1;
    const altBump     = parseInt(document.getElementById('altBumpSlider').value);
    const altCal      = parseInt(document.getElementById('altCalSlider').value);

    // Eligible devices
    const eligRaw  = document.getElementById('eligibleDevices').value;
    const eligDev  = eligRaw === '' ? devices : Math.min(parseFloat(eligRaw) || devices, devices);
    const ineligDev = devices - eligDev;

    // Split display
    const splitEl = document.getElementById('eligibleSplit');
    if (eligRaw !== '' && eligDev < devices) {
      splitEl.style.display = 'block';
      document.getElementById('eligibleCount').textContent   = Math.round(eligDev);
      document.getElementById('ineligibleCount').textContent = Math.round(ineligDev);
    } else { splitEl.style.display = 'none'; }

    // Same-interval warnings
    document.getElementById('bumpSameWarn').classList.toggle('show', altBump === curBump);
    document.getElementById('calSameWarn').classList.toggle('show',  altCal  === curCal);

    updateNudge(devices, cylSz, cylCost, tpt, hr);

    const hasData = devices > 0 && cylSz > 0 && cylCost > 0 && tpt > 0 && hr > 0;
    document.getElementById('results').style.display = hasData ? 'block' : 'none';
    if (!hasData) return;

    // Derived
    const usable   = cylSz * cylEff;
    const gpc      = gpb * 3;                         // gas per calibration
    const cpl      = cylCost / usable;                // cost per litre
    const labMin   = tpt * (1 + retest);
    const labHr    = labMin / 60;
    const labCost  = labHr * hr;
    // Confined space: calendar-based (52 fixed weeks), site-level via crew size
    const csTests  = csWk * 52 * dpcs;

    // SCENARIO A: full fleet, current intervals
    // Bump tests: working-day basis (SOPs tied to shift starts)
    // Calibrations: calendar-day basis (regulatory intervals are always calendar days)
    const sBpd = wd / curBump;
    const sCpd = 365 / curCal;
    const sBF  = sBpd * devices;
    const sCF  = sCpd * devices;
    const sGas = (sBF * gpb) + (sCF * gpc);
    const sGC  = sGas * cpl;
    const sLC  = (sBF + sCF) * labCost;
    const csG  = csTests * gpb;
    const csLC = csTests * labCost;
    const csC  = csG * cpl + csLC;
    const sT   = sGC + sLC + csC;

    // SCENARIO B: eligible on alt intervals, ineligible on current
    // Bump: working-day basis. Calibration: calendar-day basis.
    const aBpd    = wd / altBump;
    const aCpd    = 365 / altCal;
    const aBFe    = aBpd * eligDev;   const aCFe = aCpd * eligDev;
    const aBFi    = sBpd * ineligDev; const aCFi = sCpd * ineligDev;
    const aBF     = aBFe + aBFi;      const aCF  = aCFe + aCFi;
    const aGas    = (aBF * gpb) + (aCF * gpc);
    const aGC     = aGas * cpl;
    const aLC     = (aBF + aCF) * labCost;
    const aT      = aGC + aLC + csC;

    // Populate Scenario A
    set('sBumpTests',  fmtN(sBF));    set('sCalTests',  fmtN(sCF));
    set('sTotalGas',   fmtL(sGas+csG)); set('sGasCost', fmt(sGC));
    set('sLabourCost', fmt(sLC));     set('sCSCost', csWk>0 ? fmt(csC) : 'N/A');
    set('sTotal',      fmt(sT));

    // Populate Scenario B
    set('aBumpTests',  fmtN(aBF));    set('aCalTests',  fmtN(aCF));
    set('aTotalGas',   fmtL(aGas+csG)); set('aGasCost', fmt(aGC));
    set('aLabourCost', fmt(aLC));     set('aCSCost', csWk>0 ? fmt(csC) : 'N/A');
    set('aTotal',      fmt(aT));

    // Interval labels
    const BL = {1:'Daily',2:'Every 2 days',3:'Every 3 days',7:'Weekly',14:'Every 2 weeks',30:'Monthly'};
    const CL = {1:'daily cal',7:'weekly cal',14:'2-wk cal',30:'30-day cal',60:'60-day cal',90:'90-day cal',180:'180-day cal'};
    set('currentIntervalLabel', (BL[curBump]||curBump+'-day bump')+' / '+(CL[curCal]||curCal+'-day cal'));
    const altNote = (eligRaw!==''&&eligDev<devices) ? ' · '+Math.round(eligDev)+' of '+Math.round(devices)+' devices' : '';
    set('altIntervalLabel', (altBump===1?'Daily bump':altBump+'-day bump')+' / '+altCal+'-day cal'+altNote);

    // Saving banner
    const saving  = sT - aT;
    const svGas   = sGC - aGC;
    const svLab   = sLC - aLC;
    const svTests = (sBF+sCF) - (aBF+aCF);
    const svHrs   = svTests * labHr;
    const banner  = document.getElementById('savingBanner');
    const head    = document.getElementById('savingHead');
    banner.classList.add('show');

    const neg = document.getElementById('savingNeg');
    if (saving <= 0) {
      set('savingAmt', saving===0 ? '$0' : fmt(Math.abs(saving))+' additional cost');
      document.getElementById('savingAmt').style.color = saving===0 ? 'white' : '#FFB3A0';
      neg.style.display = 'block';
      neg.textContent = (altBump===curBump && altCal===curCal)
        ? 'Scenario B intervals match your current regime. Use the sliders in "Adjust Your Comparison" to model a saving.'
        : 'Your current regime is already at or near the risk-calibrated interval. Review your inputs or consult the methodology notes.';
      head.style.background = '#7A3820';
    } else {
      set('savingAmt', fmt(saving));
      document.getElementById('savingAmt').style.color = 'white';
      neg.style.display = 'none';
      head.style.background = 'var(--green)';
    }

    const pct    = sT>0 ? Math.round((saving/sT)*100) : 0;
    const devRef = (eligRaw!==''&&eligDev<devices)
      ? fmtN(eligDev)+' of '+fmtN(devices)+' devices'
      : fmtN(devices)+' device'+(devices!==1?'s':'');
    set('savingSub',    'Estimated '+Math.max(0,pct)+'% reduction in annual testing costs across '+devRef);
    set('savingGas',    fmt(svGas));
    set('savingLabour', fmt(svLab));
    set('savingTests',  fmtN(svTests)+' fewer tests/yr');
    set('savingHours',  Math.round(svHrs)+' hrs/yr');

    document.getElementById('results').classList.add('animate-in');
  }

  window.addEventListener('load', () => {
    track('altBumpSlider', 1, 30);
    track('altCalSlider', 30, 180);
  });
</script>
