  function onSliderChange() {
    const bumpVal = parseInt(document.getElementById('altBumpSlider').value);
    const calVal  = parseInt(document.getElementById('altCalSlider').value);
    document.getElementById('altBumpDisplay').textContent = bumpVal;
    document.getElementById('altCalDisplay').textContent  = calVal;
    updateSliderTrack('altBumpSlider', 1, 30);
    updateSliderTrack('altCalSlider', 30, 180);
    calculate();
  }

  function updateSliderTrack(id, min, max) {
    const slider = document.getElementById(id);
    const pct = ((parseInt(slider.value) - min) / (max - min)) * 100;
    slider.style.background = `linear-gradient(to right, var(--red) ${pct}%, var(--border) ${pct}%)`;
  }

  // ── FORMAT HELPERS ──
  function fmt(n) {
    if (n === null || n === undefined || isNaN(n)) return '-';
    return '$' + Math.round(n).toLocaleString('en-US');
  }
  function fmtN(n) {
    if (n === null || n === undefined || isNaN(n)) return '-';
    return Math.round(n).toLocaleString('en-US');
  }
  function fmtL(n) {
    if (!n) return '-';
    return Math.round(n).toLocaleString('en-US') + ' L';
  }
  function getVal(id, fallback) {
    const v = parseFloat(document.getElementById(id).value);
    return isNaN(v) ? (fallback !== undefined ? fallback : 0) : v;
  }

  // ── PROGRESS NUDGE ──
  function updateNudge(devices, cylSize, cylCost, timePerTest, hourlyRate) {
    const missing = [];
    if (!devices)     missing.push('number of devices');
    if (!cylSize)     missing.push('cylinder size');
    if (!cylCost)     missing.push('cylinder cost');
    if (!timePerTest) missing.push('time per test');
    if (!hourlyRate)  missing.push('hourly rate');

    const nudge = document.getElementById('progressNudge');
    const hasPartial = (devices || cylSize || cylCost || timePerTest || hourlyRate) && missing.length > 0;

    if (hasPartial) {
      document.getElementById('nudgeFields').textContent = missing.join(', ');
      nudge.classList.add('visible');
    } else {
      nudge.classList.remove('visible');
    }
  }

  // ── RESET ──
  function resetAll() {
    document.getElementById('devices').value        = '';
    document.getElementById('workingDays').value    = '220';
    document.getElementById('customDays').value     = '';
    document.getElementById('customDaysField').style.display = 'none';
    document.getElementById('currentBump').value    = '1';
    document.getElementById('currentCal').value     = '30';
    document.getElementById('cylinderSize').value   = '';
    document.getElementById('cylinderCost').value   = '';
    document.getElementById('gasPerBump').value     = '';
    document.getElementById('timePerTest').value    = '';
    document.getElementById('hourlyRate').value     = '';
    document.getElementById('cylinderEff').value    = '0.85';
    document.getElementById('retestRate').value     = '0';
    document.getElementById('confinedSpace').value  = '';
    document.getElementById('devicesPerCS').value   = '';
    document.getElementById('eligibleDevices').value = '';
    document.getElementById('eligibleSplit').style.display = 'none';
    document.getElementById('altBumpSlider').value  = '30';
    document.getElementById('altCalSlider').value   = '180';
    document.getElementById('altBumpDisplay').textContent = '30';
    document.getElementById('altCalDisplay').textContent  = '180';
    updateSliderTrack('altBumpSlider', 1, 30);
    updateSliderTrack('altCalSlider', 30, 180);
    document.getElementById('bumpSameWarning').classList.remove('visible');
    document.getElementById('calSameWarning').classList.remove('visible');
    document.getElementById('results').style.display = 'none';
    document.getElementById('progressNudge').classList.remove('visible');
    document.getElementById('savingBanner').classList.remove('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── CORE CALCULATION ──
  function calculate() {
    const devices       = getVal('devices', 0);
    const wdSel         = document.getElementById('workingDays').value;
    const workingDays   = wdSel === 'custom' ? getVal('customDays', 220) : parseFloat(wdSel);
    const currentBump   = getVal('currentBump', 1);
    const currentCal    = getVal('currentCal', 30);
    const cylSize       = getVal('cylinderSize', 0);
    const cylCost       = getVal('cylinderCost', 0);
    const gasPerBump    = getVal('gasPerBump', 0) || 0.5;
    const timePerTest   = getVal('timePerTest', 0);
    const hourlyRate    = getVal('hourlyRate', 0);
    const cylEff        = parseFloat(document.getElementById('cylinderEff').value);
    const retestRate    = parseFloat(document.getElementById('retestRate').value);
    const csPerWeek     = getVal('confinedSpace', 0);
    const devicesPerCS  = getVal('devicesPerCS', 0) || 1;

    // Slider values
    const altBumpInterval = parseInt(document.getElementById('altBumpSlider').value);
    const altCalInterval  = parseInt(document.getElementById('altCalSlider').value);

    // Same-interval warnings
    const bumpSame = altBumpInterval === currentBump;
    const calSame  = altCalInterval  === currentCal;
    document.getElementById('bumpSameWarning').classList.toggle('visible', bumpSame);
    document.getElementById('calSameWarning').classList.toggle('visible', calSame);

    // Dynamic Scenario B interval label
    const altBumpLabel = altBumpInterval === 1 ? 'Daily bump' : altBumpInterval + '-day bump';
    const altCalLabel  = altCalInterval  + '-day cal';
    const eligibleNote = (eligibleRaw !== '' && eligibleDevices < devices)
      ? ' · ' + Math.round(eligibleDevices) + ' of ' + Math.round(devices) + ' devices'
      : '';
    document.getElementById('altIntervalLabel').textContent = altBumpLabel + ' / ' + altCalLabel + eligibleNote;

    updateNudge(devices, cylSize, cylCost, timePerTest, hourlyRate);

    const hasData = devices > 0 && cylSize > 0 && cylCost > 0 && timePerTest > 0 && hourlyRate > 0;
    document.getElementById('results').style.display = hasData ? 'block' : 'none';
    if (!hasData) return;

    // Derived
    const usableGasPerCyl  = cylSize * cylEff;
    const gasPerCal        = gasPerBump * 3;
    const costPerLitre     = cylCost / usableGasPerCyl;
    const labourPerTestMin = timePerTest * (1 + retestRate);
    const labourPerTestHr  = labourPerTestMin / 60;
    const labourPerTest    = labourPerTestHr * hourlyRate;
    const csWeeks          = workingDays / 5;
    const csTotalTests     = csPerWeek * csWeeks * devicesPerCS;

    // ── SCENARIO A ──
    const sBumpsPerDevice = workingDays / currentBump;
    const sCalsPerDevice  = workingDays / currentCal;
    const sBumpFleet      = sBumpsPerDevice * devices;
    const sCalFleet       = sCalsPerDevice  * devices;
    const sRoutineGas     = (sBumpFleet * gasPerBump) + (sCalFleet * gasPerCal);
    const sGasCostVal     = sRoutineGas * costPerLitre;
    const sLabourCostVal  = (sBumpFleet + sCalFleet) * labourPerTest;
    const sCsGas          = csTotalTests * gasPerBump;
    const sCsLabour       = csTotalTests * labourPerTest;
    const sCsCostVal      = sCsGas * costPerLitre + sCsLabour;
    const sTotalVal       = sGasCostVal + sLabourCostVal + sCsCostVal;

    // ── ELIGIBLE DEVICES SPLIT ──
    // If blank, full fleet is eligible. If entered, clamp to fleet size.
    const eligibleRaw     = document.getElementById('eligibleDevices').value;
    const eligibleDevices = eligibleRaw === '' ? devices : Math.min(parseFloat(eligibleRaw) || devices, devices);
    const ineligible      = devices - eligibleDevices;

    // Show/hide the split display
    const splitEl = document.getElementById('eligibleSplit');
    if (eligibleRaw !== '' && eligibleDevices < devices) {
      splitEl.style.display = 'block';
      document.getElementById('eligibleCount').textContent    = Math.round(eligibleDevices);
      document.getElementById('ineligibleCount').textContent  = Math.round(ineligible);
    } else {
      splitEl.style.display = 'none';
    }

    // ── SCENARIO B (slider-driven, eligible devices only) ──
    // Eligible devices: move to alternative intervals
    // Ineligible devices: stay on current Scenario A intervals (cost cancels in saving calc)
    const aBumpsPerDevice     = workingDays / altBumpInterval;
    const aCalsPerDevice      = workingDays / altCalInterval;
    const aBumpFleetEligible  = aBumpsPerDevice * eligibleDevices;
    const aCalFleetEligible   = aCalsPerDevice  * eligibleDevices;
    // Ineligible portion stays on current regime in Scenario B
    const aBumpFleetInelig    = sBumpsPerDevice * ineligible;
    const aCalFleetInelig     = sCalsPerDevice  * ineligible;
    const aBumpFleet          = aBumpFleetEligible + aBumpFleetInelig;
    const aCalFleet           = aCalFleetEligible  + aCalFleetInelig;
    const aRoutineGas     = (aBumpFleet * gasPerBump) + (aCalFleet * gasPerCal);
    const aGasCostVal     = aRoutineGas * costPerLitre;
    const aLabourCostVal  = (aBumpFleet + aCalFleet) * labourPerTest;
    const aCsCostVal      = sCsCostVal;
    const aTotalVal       = aGasCostVal + aLabourCostVal + aCsCostVal;

    // ── POPULATE A ──
    document.getElementById('sBumpTests').textContent   = fmtN(sBumpFleet);
    document.getElementById('sCalTests').textContent    = fmtN(sCalFleet);
    document.getElementById('sTotalGas').textContent    = fmtL(sRoutineGas + sCsGas);
    document.getElementById('sGasCost').textContent     = fmt(sGasCostVal);
    document.getElementById('sLabourCost').textContent  = fmt(sLabourCostVal);
    document.getElementById('sCSCost').textContent      = csPerWeek > 0 ? fmt(sCsCostVal) : 'N/A';
    document.getElementById('sTotal').textContent       = fmt(sTotalVal);

    // ── POPULATE B ──
    document.getElementById('aBumpTests').textContent   = fmtN(aBumpFleet);
    document.getElementById('aCalTests').textContent    = fmtN(aCalFleet);
    document.getElementById('aTotalGas').textContent    = fmtL(aRoutineGas + sCsGas);
    document.getElementById('aGasCost').textContent     = fmt(aGasCostVal);
    document.getElementById('aLabourCost').textContent  = fmt(aLabourCostVal);
    document.getElementById('aCSCost').textContent      = csPerWeek > 0 ? fmt(aCsCostVal) : 'N/A';
    document.getElementById('aTotal').textContent       = fmt(aTotalVal);

    // ── INTERVAL LABEL (Scenario A) ──
    const bumpLabels = {1:'Daily',2:'Every 2 days',3:'Every 3 days',7:'Weekly',14:'Every 2 weeks',30:'Monthly'};
    const calLabels  = {1:'daily cal',7:'weekly cal',14:'2-week cal',30:'30-day cal',60:'60-day cal',90:'90-day cal',180:'180-day cal'};
    const bLabel = bumpLabels[currentBump] || (currentBump + '-day bump');
    const cLabel = calLabels[currentCal]   || (currentCal + '-day cal');
    document.getElementById('currentIntervalLabel').textContent = bLabel + ' / ' + cLabel;

    // ── SAVING BANNER ──
    const saving       = sTotalVal - aTotalVal;
    const savingGasVal = sGasCostVal - aGasCostVal;
    const savingLab    = sLabourCostVal - aLabourCostVal;
    const savingTests  = (sBumpFleet + sCalFleet) - (aBumpFleet + aCalFleet);
    const savingHrs    = savingTests * labourPerTestHr;

    const banner       = document.getElementById('savingBanner');
    const bannerHeader = document.getElementById('savingBannerHeader');
    banner.classList.add('visible');

    const negNote = document.getElementById('savingNegative');
    if (saving <= 0) {
      const isIdentical = bumpSame && calSame;
      document.getElementById('savingAmount').textContent = saving === 0 ? '$0' : fmt(Math.abs(saving)) + ' additional cost';
      document.getElementById('savingAmount').style.color = saving === 0 ? 'white' : '#FFB3A0';
      negNote.style.display = 'block';
      negNote.textContent = isIdentical
        ? 'Scenario B intervals match your current regime exactly — set the sliders to a less frequent interval to model a saving.'
        : saving === 0
          ? 'The two scenarios produce the same cost. Adjust the sliders to see a meaningful comparison.'
          : 'Your current regime is already at or near the risk-calibrated interval. The alternative scenario costs more in this configuration. Review your inputs or consult the methodology notes.';
      bannerHeader.style.background = '#7A3820';
    } else {
      document.getElementById('savingAmount').textContent = fmt(saving);
      document.getElementById('savingAmount').style.color = 'white';
      negNote.style.display = 'none';
      bannerHeader.style.background = 'var(--green)';
    }

    const pct = sTotalVal > 0 ? Math.round((saving / sTotalVal) * 100) : 0;
    const deviceRef = (eligibleRaw !== '' && eligibleDevices < devices)
      ? fmtN(eligibleDevices) + ' of ' + fmtN(devices) + ' devices'
      : fmtN(devices) + ' device' + (devices !== 1 ? 's' : '');
    document.getElementById('savingSubtext').textContent =
      'Estimated ' + Math.max(0, pct) + '% reduction in annual testing costs across ' + deviceRef;
    document.getElementById('savingGas').textContent    = fmt(savingGasVal);
    document.getElementById('savingLabour').textContent = fmt(savingLab);
    document.getElementById('savingTests').textContent  = fmtN(savingTests) + ' fewer tests/yr';
    document.getElementById('savingHours').textContent  = Math.round(savingHrs) + ' hrs/yr';

    document.getElementById('results').classList.add('animate-in');
  }

  // Initialise slider tracks on load
  window.addEventListener('load', function() {
    updateSliderTrack('altBumpSlider', 1, 30);
    updateSliderTrack('altCalSlider', 30, 180);
  });
</script>
