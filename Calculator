<script>
  // ── CURRENCY SYSTEM ──
  const CURRENCIES = {
    USD: { sym:'$',   label:'USD', locale:'en-US' },
    CAD: { sym:'CA$', label:'CAD', locale:'en-CA' },
    AUD: { sym:'A$',  label:'AUD', locale:'en-AU' },
    GBP: { sym:'\u00a3',  label:'GBP', locale:'en-GB' },
    EUR: { sym:'\u20ac',  label:'EUR', locale:'de-DE' },
  };
  let currSym    = '$';
  let currLocale = 'en-US';

  function setCurrency(code) {
    const c = CURRENCIES[code] || CURRENCIES.USD;
    currSym    = c.sym;
    currLocale = c.locale;
    // Update input prefix symbols
    document.getElementById('cylCostPrefix').textContent    = currSym;
    document.getElementById('hourlyRatePrefix').textContent = currSym;
    // Adjust left padding dynamically to prevent symbol overlapping placeholder text
    // Single char ($, £, €): 28px | Two chars (CA$, A$): 40px | fallback: 48px
    const symLen = currSym.length;
    const pad = symLen <= 1 ? '28px' : symLen === 2 ? '38px' : '46px';
    ['cylinderCost','hourlyRate'].forEach(id => {
      document.getElementById(id).style.paddingLeft = pad;
    });
    calculate();
  }

  // ── TOOLTIP ENGINE ──
  const tipBubble = document.getElementById('tipBubble');
  let tipTimer;
  document.addEventListener('mouseover', e => {
    const icon = e.target.closest('.tip-icon');
    if (!icon) return;
    clearTimeout(tipTimer);
    tipBubble.textContent = icon.dataset.tip || '';
    placeTip(icon);
    tipBubble.classList.add('show');
  });
  document.addEventListener('mouseout', e => {
    if (e.target.closest('.tip-icon')) tipTimer = setTimeout(() => tipBubble.classList.remove('show'), 80);
  });
  window.addEventListener('scroll', () => tipBubble.classList.remove('show'), { passive:true });
  window.addEventListener('resize', () => tipBubble.classList.remove('show'), { passive:true });

  function placeTip(icon) {
    const W = 240, M = 10;
    const vw = window.innerWidth, vh = window.innerHeight;
    const r  = icon.getBoundingClientRect();
    tipBubble.style.cssText = `width:${W}px;top:-9999px;left:-9999px;display:block`;
    const bh = tipBubble.offsetHeight;
    tipBubble.style.display = '';
    let left = Math.min(Math.max(r.left, M), vw - W - M);
    let top  = r.top - bh - 8;
    if (top < M) top = r.bottom + 8;
    top = Math.min(top, vh - bh - M);
    tipBubble.style.cssText = `width:${W}px;left:${left}px;top:${top}px`;
  }

  // ── TESTING METHOD DEFAULTS ──
  const MODES = {
    manual: {
      gpb:0.3, calMult:4.0, cylEff:0.85,
      tptFallback: 3, labMultFallback: 2.5,
      gpbPlaceholder: 'e.g. 0.3', calMultPlaceholder: 'e.g. 4',
      tptPlaceholder: 'e.g. 3',   labMultPlaceholder: 'e.g. 2.5',
      gpbHint: '0.3L per bump test (four-gas monitor, manual)',
      calHint: '4x (four-gas monitor, manual: 0.3L bump, ~1.2L cal)',
      tptHint: 'Manual: under 3 min per bump test for four-gas',
      labMultHint: '2.5x (manual: bump under 3 min, calibration under 7 min)',
      tptTip:  'Minutes per bump test, including setup, sensor exposure, and logging. For manual four-gas testing, bump tests typically take under 3 minutes per device. Calibration time is handled separately via the Labour Time Multiplier in Advanced Assumptions.',
    },
    docked: {
      gpb:0.15, calMult:6.0, cylEff:0.90,
      tptFallback: 1, labMultFallback: 3.0,
      gpbPlaceholder: 'e.g. 0.15', calMultPlaceholder: 'e.g. 6',
      tptPlaceholder: 'e.g. 1',    labMultPlaceholder: 'e.g. 3',
      gpbHint: '0.15L per bump test (docking station, metered short-duration flow)',
      calHint: '6x (docked: 0.15L bump vs ~1L cal makes ratio higher than manual)',
      tptHint: 'Docked: ~1 min per bump test (sequential). Reduce for multi-bay stations.',
      labMultHint: '3x (docked: bump ~1 min, calibration 2 to 5 min)',
      tptTip:  'Minutes per bump test for handling only: loading the device and retrieving it after the cycle completes. For sequential single-device loading this is approximately 1 minute. For multi-bay stations where devices are loaded simultaneously, the effective per-device time is much lower. Calibration handling time is derived separately via the Labour Time Multiplier in Advanced Assumptions.',
    },
  };

  let currentMode = 'manual';
  let toastTimer;

  function showToast(msg) {
    const t = document.getElementById('modeToast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
  }

  function setMode(mode) {
    const isSwitch = mode !== currentMode;
    currentMode = mode;
    ['manual','docked'].forEach(m => {
      document.getElementById('tab-'+m).classList.toggle('active', m === mode);
    });

    const d = MODES[mode];

    // cylEff: always set directly: lives in hidden panel, user cannot see it
    document.getElementById('cylinderEff').value = String(d.cylEff);

    // gpb, calMult, tpt, labMult: never pre-fill.
    // Clear on mode switch so placeholders and hints reflect the new mode.
    // The calculation uses fallback values silently when fields are empty.
    if (isSwitch) {
      document.getElementById('gasPerBump').value  = '';
      document.getElementById('calMult').value     = '';
      document.getElementById('timePerTest').value = '';
      document.getElementById('labMult').value     = '';
    }

    // Update placeholders dynamically to reflect active mode suggestion
    document.getElementById('gasPerBump').placeholder  = d.gpbPlaceholder;
    document.getElementById('calMult').placeholder     = d.calMultPlaceholder;
    document.getElementById('timePerTest').placeholder = d.tptPlaceholder;
    document.getElementById('labMult').placeholder     = d.labMultPlaceholder;

    // Update hint text and dynamic tooltip
    document.getElementById('gpbHint').textContent     = 'Typical: ' + d.gpbHint;
    document.getElementById('calHint').textContent     = 'Typical: ' + d.calHint;
    document.getElementById('tptHint').textContent     = d.tptHint;
    document.getElementById('labMultHint').textContent = 'Typical: ' + d.labMultHint;
    const tptIcon = document.getElementById('tptTipIcon');
    if (tptIcon) tptIcon.dataset.tip = d.tptTip;

    if (isSwitch) {
      const label = mode === 'docked' ? 'Docking Station' : 'Manual Testing';
      showToast(label + ' defaults applied');
    }

    calculate();
  }

  // ── TOGGLES ──
  function toggleAdjust() {
    const body = document.getElementById('adjustBody');
    const head = document.getElementById('adjustHeader');
    const open = body.classList.toggle('open');
    head.classList.toggle('open', open);
  }
  function toggleMeth() {
    const body  = document.getElementById('methBody');
    const label = document.getElementById('methLabel');
    body.classList.toggle('open');
    label.innerHTML = body.classList.contains('open')
      ? 'Hide <span style="font-size:10px;margin-left:4px">&#9650;</span>'
      : 'Show <span style="font-size:10px;margin-left:4px">&#9660;</span>';
  }
  function handleWD() {
    document.getElementById('customDaysField').style.display =
      document.getElementById('workingDays').value === 'custom' ? 'block' : 'none';
    calculate();
  }

  // ── SLIDERS ──
  function onSlider() {
    const bv = parseInt(document.getElementById('altBumpSlider').value);
    const cv = parseInt(document.getElementById('altCalSlider').value);
    document.getElementById('altBumpDisplay').textContent = bv;
    document.getElementById('altCalDisplay').textContent  = cv;
    track('altBumpSlider', 1, 30);
    track('altCalSlider', 30, 180);
    calculate();
  }
  function track(id, min, max) {
    const s = document.getElementById(id);
    const p = ((parseInt(s.value) - min) / (max - min)) * 100;
    s.style.background = `linear-gradient(to right,var(--red) ${p}%,var(--border) ${p}%)`;
  }

  // ── FORMATTERS ──
  const fmt  = n => (n == null || isNaN(n)) ? '-' : currSym + Math.round(n).toLocaleString(currLocale);
  const fmtN = n => (n == null || isNaN(n)) ? '-' : Math.round(n).toLocaleString(currLocale);
  const fmtL = n => (!n || isNaN(n))        ? '-' : Math.round(n).toLocaleString(currLocale) + ' L';
  const gv   = (id, fb=0) => { const v = parseFloat(document.getElementById(id).value); return isNaN(v) ? fb : v; };
  const set  = (id, v)    => { document.getElementById(id).textContent = v; };

  // ── PROGRESS NUDGE ──
  // tpt and cylEff have mode defaults so are never required from the user
  function updateNudge(d, cs, cc, hr) {
    const miss = [];
    if (!d)  miss.push('number of devices');
    if (!cs) miss.push('cylinder size');
    if (!cc) miss.push('cylinder cost');
    if (!hr) miss.push('hourly rate');
    const partial = (d||cs||cc||hr) && miss.length;
    const el = document.getElementById('progressNudge');
    if (partial) { document.getElementById('nudgeFields').textContent = miss.join(', '); el.classList.add('visible'); }
    else { el.classList.remove('visible'); }
  }

  // ── RESET ──
  function resetAll() {
    // Clear all user-entered fields including mode-defaulted ones
    ['devices','customDays','cylinderSize','cylinderCost','gasPerBump','calMult','labMult','timePerTest',
     'hourlyRate','confinedSpace','devicesPerCS','eligibleDevices']
      .forEach(id => document.getElementById(id).value = '');
    document.getElementById('currencySelect').value = 'USD';
    setCurrency('USD');
    document.getElementById('workingDays').value = '220';
    document.getElementById('currentBump').value = '1';
    document.getElementById('currentCal').value  = '30';
    document.getElementById('retestRate').value  = '0';
    document.getElementById('customDaysField').style.display = 'none';
    document.getElementById('altBumpSlider').value = '30';
    document.getElementById('altCalSlider').value  = '180';
    document.getElementById('altBumpDisplay').textContent = '30';
    document.getElementById('altCalDisplay').textContent  = '180';
    track('altBumpSlider', 1, 30);
    track('altCalSlider', 30, 180);
    ['bumpSameWarn','calSameWarn'].forEach(id => document.getElementById(id).classList.remove('show'));
    document.getElementById('eligibleSplit').style.display = 'none';
    document.getElementById('results').style.display = 'none';
    document.getElementById('progressNudge').classList.remove('visible');
    document.getElementById('savingBanner').classList.remove('show');
    // Reset to manual mode
    setMode('manual');
    window.scrollTo({ top:0, behavior:'smooth' });
  }

  // ── CORE CALCULATION ──
  function calculate() {
    const devices    = gv('devices');
    const wdSel      = document.getElementById('workingDays').value;
    const wd         = wdSel === 'custom' ? gv('customDays', 220) : parseFloat(wdSel);
    const curBump    = gv('currentBump', 1);
    const curCal     = gv('currentCal', 30);
    const cylSz      = gv('cylinderSize');
    const cylCost    = gv('cylinderCost');
    const hr         = gv('hourlyRate');
    const retest     = parseFloat(document.getElementById('retestRate').value);
    const csWk       = gv('confinedSpace');
    const dpcs       = gv('devicesPerCS') || 1;
    const altBump    = parseInt(document.getElementById('altBumpSlider').value);
    const altCal     = parseInt(document.getElementById('altCalSlider').value);

    // ── MODE-AWARE INPUTS ──
    const mode    = currentMode;
    const d       = MODES[mode];
    let gpb, calMult, cylEff, tpt, labMult;

    gpb     = gv('gasPerBump')  || d.gpb;
    calMult = gv('calMult')     || d.calMult;
    tpt     = gv('timePerTest') || d.tptFallback;
    labMult = gv('labMult')     || d.labMultFallback;
    const rawEff = parseFloat(document.getElementById('cylinderEff').value);
    cylEff = isNaN(rawEff) ? d.cylEff : rawEff;

    // Eligible devices
    const eligRaw   = document.getElementById('eligibleDevices').value;
    const eligDev   = eligRaw === '' ? devices : Math.min(parseFloat(eligRaw) || devices, devices);
    const ineligDev = devices - eligDev;

    // Split display
    const splitEl = document.getElementById('eligibleSplit');
    if (eligRaw !== '' && eligDev < devices) {
      splitEl.style.display = 'block';
      document.getElementById('eligibleCount').textContent   = Math.round(eligDev);
      document.getElementById('ineligibleCount').textContent = Math.round(ineligDev);
    } else { splitEl.style.display = 'none'; }

    // Same-interval warnings
    document.getElementById('bumpSameWarn').classList.toggle('show', altBump === curBump);
    document.getElementById('calSameWarn').classList.toggle('show',  altCal  === curCal);

    // hasData: only gate on fields the user must explicitly provide
    // tpt and cylEff both have mode defaults so never block results
    updateNudge(devices, cylSz, cylCost, hr);

    const hasData = devices > 0 && cylSz > 0 && cylCost > 0 && hr > 0;
    document.getElementById('results').style.display = hasData ? 'block' : 'none';
    if (!hasData) return;

    // Derived
    const usable      = cylSz * cylEff;
    const gpc         = gpb * calMult;
    const cpl         = cylCost / usable;
    const tptCal      = tpt * labMult;
    const labHrBump   = tpt    * (1 + retest) / 60;
    const labHrCal    = tptCal * (1 + retest) / 60;
    const labCostBump = labHrBump * hr;
    const labCostCal  = labHrCal  * hr;
    const csTests     = csWk * 52 * dpcs;

    // SCENARIO A: full fleet, current intervals
    const sBpd = wd / curBump;
    const sCpd = 365 / curCal;
    const sBF  = sBpd * devices;
    const sCF  = sCpd * devices;
    const sGas = (sBF * gpb) + (sCF * gpc);
    const sGC  = sGas * cpl;
    const sLC  = (sBF * labCostBump) + (sCF * labCostCal);
    const csG  = csTests * gpb;
    const csLC = csTests * labCostBump;
    const csC  = csG * cpl + csLC;
    const sT   = sGC + sLC + csC;

    // SCENARIO B: eligible on alt intervals, ineligible on current
    const aBpd    = wd / altBump;
    const aCpd    = 365 / altCal;
    const aBFe    = aBpd * eligDev;    const aCFe = aCpd * eligDev;
    const aBFi    = sBpd * ineligDev;  const aCFi = sCpd * ineligDev;
    const aBF     = aBFe + aBFi;       const aCF  = aCFe + aCFi;
    const aGas    = (aBF * gpb) + (aCF * gpc);
    const aGC     = aGas * cpl;
    const aLC     = (aBF * labCostBump) + (aCF * labCostCal);
    const aT      = aGC + aLC + csC;

    // Populate Scenario A
    set('sBumpTests',  fmtN(sBF));      set('sCalTests',  fmtN(sCF));
    set('sTotalGas',   fmtL(sGas+csG)); set('sGasCost',   fmt(sGC));
    set('sLabourCost', fmt(sLC));       set('sCSCost',     csWk>0 ? fmt(csC) : 'N/A');
    set('sTotal',      fmt(sT));

    // Populate Scenario B
    set('aBumpTests',  fmtN(aBF));      set('aCalTests',  fmtN(aCF));
    set('aTotalGas',   fmtL(aGas+csG)); set('aGasCost',   fmt(aGC));
    set('aLabourCost', fmt(aLC));       set('aCSCost',     csWk>0 ? fmt(csC) : 'N/A');
    set('aTotal',      fmt(aT));

    // Show/hide confined space rows: only visible when user has entered CS entries
    document.querySelectorAll('.cs-line').forEach(el => {
      el.classList.toggle('hidden', csWk === 0);
    });

    // Interval labels
    const BL = {1:'Daily',2:'Every 2 days',3:'Every 3 days',7:'Weekly',14:'Every 2 weeks',30:'Monthly'};
    const CL = {1:'daily cal',7:'weekly cal',14:'2-wk cal',30:'30-day cal',60:'60-day cal',90:'90-day cal',180:'180-day cal'};
    set('currentIntervalLabel', (BL[curBump]||curBump+'-day bump')+' / '+(CL[curCal]||curCal+'-day cal'));
    const altNote = (eligRaw!==''&&eligDev<devices) ? ' · '+Math.round(eligDev)+' of '+Math.round(devices)+' devices' : '';
    set('altIntervalLabel', (altBump===1?'Daily bump':altBump+'-day bump')+' / '+altCal+'-day cal'+altNote);

    // ── SAVING BANNER ──
    const saving  = sT - aT;
    const svGas   = sGC - aGC;
    const svLab   = sLC - aLC;
    const svBumps = sBF - aBF;
    const svCals  = sCF - aCF;
    const svTests = (sBF+sCF) - (aBF+aCF);
    const svHrs   = (svBumps * labHrBump) + (svCals * labHrCal);
    const banner  = document.getElementById('savingBanner');
    const head    = document.getElementById('savingHead');
    banner.classList.add('show');

    const neg = document.getElementById('savingNeg');
    if (saving <= 0) {
      set('savingAmt', saving===0 ? currSym+'0' : fmt(Math.abs(saving))+' additional cost');
      document.getElementById('savingAmt').style.color = saving===0 ? 'white' : '#FFB3A0';
      neg.style.display = 'block';
      neg.textContent = (altBump===curBump && altCal===curCal)
        ? 'Scenario B intervals match your current regime. Use the sliders in "Adjust Your Comparison" to model a saving.'
        : 'Your current regime is already at or near the risk-calibrated interval. Review your inputs or consult the methodology notes.';
      head.style.background = '#7A3820';
    } else {
      set('savingAmt', fmt(saving));
      document.getElementById('savingAmt').style.color = 'white';
      neg.style.display = 'none';
      head.style.background = 'var(--green)';
    }

    const pct    = sT>0 ? Math.round((saving/sT)*100) : 0;
    const devRef = (eligRaw!==''&&eligDev<devices)
      ? fmtN(eligDev)+' of '+fmtN(devices)+' devices'
      : fmtN(devices)+' device'+(devices!==1?'s':'');
    set('savingSub', 'Estimated '+Math.max(0,pct)+'% reduction in annual testing costs across '+devRef);

    // Populate saving items
    set('savingGas',    fmt(svGas));
    set('savingLabour', fmt(svLab));
    set('savingTests',  fmtN(svTests)+' fewer tests/yr');
    set('savingHours',  Math.round(svHrs)+' hrs/yr');

    // Dynamic ordering: gas leads when it is the larger saving (docked) or equal
    // Labour leads only when it is strictly larger (manual with significant time saving)
    const grid = document.getElementById('savingGrid');
    const itemGas    = document.getElementById('item-gas');
    const itemLabour = document.getElementById('item-labour');
    if (svLab > svGas && svLab > 0) {
      grid.insertBefore(itemLabour, grid.firstChild);
    } else {
      grid.insertBefore(itemGas, grid.firstChild);
    }

    // Gas callout: show in docked mode when gas saving is positive and dominant
    const callout = document.getElementById('savingGasCallout');
    const gasIsDominant = svGas > 0 && svGas >= svLab;
    const isDocked = mode === 'docked';
    if (gasIsDominant && isDocked && saving > 0) {
      const calSvPct = sCF > 0 ? Math.round(((sCF - aCF) / sCF) * 100) : 0;
      callout.innerHTML = '<strong>Calibration gas is the primary saving driver.</strong> Moving from ' +
        (CL[curCal]||curCal+'-day') + ' to ' + altCal + '-day calibration intervals reduces annual calibration events by ' +
        calSvPct + '%, which accounts for the majority of the gas saving in a docking station environment.';
      callout.classList.add('show');
    } else {
      callout.classList.remove('show');
    }

    // Labour caveat: show in docked mode to flag multi-bay station limitation
    const labCaveat = document.getElementById('savingLabourCaveat');
    if (isDocked && svLab > 0 && saving > 0) {
      labCaveat.textContent = 'Note: this figure assumes sequential device handling. In docking station environments with multi-bay stations, devices loaded simultaneously reduce the effective per-device time significantly. The gas saving above is not affected.';
      labCaveat.style.display = 'block';
    } else {
      labCaveat.style.display = 'none';
    }

    document.getElementById('results').classList.add('animate-in');
  }

  window.addEventListener('load', () => {
    track('altBumpSlider', 1, 30);
    track('altCalSlider', 30, 180);
    setCurrency('USD');
    setMode('manual');
  });
</script>
</body>
</html>
